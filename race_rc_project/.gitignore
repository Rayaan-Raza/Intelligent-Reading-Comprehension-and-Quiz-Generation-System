# Ignore all data artifacts by default
data/**

# Keep the folder structure tracked
!data/
!data/raw/
!data/processed/

# Allow small placeholders if needed
!data/raw/.gitkeep
!data/processed/.gitkeep

# Python cache and tooling
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Model/report artifacts
models/**/*
reports/**/*
figures/**/*
*.pkl

# Keep directory structure if needed
!models/
!reports/
!figures/
!models/.gitkeep
!reports/.gitkeep
!figures/.gitkeep

# OS/editor files
.DS_Store
Thumbs.db
